generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @default(uuid())
  authUid   String   @unique @map("auth_uid")
  name      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leads     Lead[]
  templates Template[]
  operators Operator[]
  cadences  CadenceEngine[]
  notifications Notification[]

  @@map("profiles")
}

model Lead {
  id            String     @id @default(uuid())
  profileId     String     @map("profile_id")
  code          String     @unique @default(cuid())
  fullName      String     @map("full_name")
  company       String?
  jobTitle      String?    @map("job_title")
  email         String?
  phone         String?
  linkedinUrl   String?    @map("linkedin_url")
  whatsappUrl   String?    @map("whatsapp_url")
  status        LeadStatus @default(NOVO)
  source        LeadSource @default(MANUAL)
  notes          String?
  importBatchId  String?    @map("import_batch_id")
  customSource   String?    @map("custom_source")
  lastOperatorId String?    @map("last_operator_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  profile      Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lastOperator Operator?     @relation(fields: [lastOperatorId], references: [id], onDelete: SetNull)
  histories    LeadHistory[]
  leadNotes    LeadNote[]
  
  // Nova relação de Cadência (Nomenclatura disruptiva para quebrar cache)
  cadenceEngine LeadCadenceProgress?

  @@index([profileId])
  @@index([lastOperatorId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

model CadenceEngine {
  id          String         @id @default(uuid())
  profileId   String?        @map("profile_id") 
  name        String
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  profile     Profile?       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  stages      CadenceStage[]
  progressions LeadCadenceProgress[]

  @@index([profileId])
  @@map("cadences")
}

model CadenceStage {
  id             String          @id @default(uuid())
  cadenceId      String          @map("cadence_id")
  order          Int             
  channel        TemplateChannel
  delayDays      Int             @map("delay_days")
  templateId     String?         @map("template_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  cadence        CadenceEngine   @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  template       Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  
  @@index([cadenceId])
  @@index([templateId])
  @@map("cadence_stages")
}

model LeadCadenceProgress {
  id               String        @id @default(uuid())
  profileId        String        @map("profile_id")
  leadId           String        @unique @map("lead_id") 
  cadenceId        String        @map("cadence_id")
  
  currentStageOrder Int          @default(1) @map("current_stage_order")
  nextStageOrder    Int?         @map("next_stage_order")
  status           CadenceStatus @default(ACTIVE)
  
  pausedAt         DateTime?     @map("paused_at")
  finishedAt       DateTime?     @map("finished_at")
  exitReason       String?       @map("exit_reason")
  nextScheduledAt  DateTime      @map("next_scheduled_at")
  lastActionAt     DateTime      @default(now()) @map("last_action_at")
  version          Int           @default(0)
  lockedAt         DateTime?     @map("locked_at")
  lockedBy         String?       @map("locked_by")

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  cadence CadenceEngine @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  events  LeadCadenceEvent[]

  @@index([profileId, status, nextScheduledAt])
  @@index([leadId])
  @@map("lead_cadence_progress")
}

model LeadCadenceEvent {
  id                     String   @id @default(uuid())
  leadCadenceProgressId  String   @map("lead_cadence_id")
  leadId                 String   @map("lead_id") 
  action                 String   
  fromStage              Int?     @map("from_stage")
  toStage                Int?     @map("to_stage")
  operatorId             String?  @map("operator_id")
  notes                  String?
  createdAt              DateTime @default(now()) @map("created_at")

  progression LeadCadenceProgress @relation(fields: [leadCadenceProgressId], references: [id], onDelete: Cascade)
  
  @@index([leadCadenceProgressId])
  @@index([leadId])
  @@map("lead_cadence_events")
}

model Template {
  id        String          @id @default(uuid())
  profileId String          @map("profile_id")
  name      String
  channel   TemplateChannel
  subject   String?
  body      String
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cadenceStages CadenceStage[]

  @@index([profileId])
  @@index([channel])
  @@map("templates")
}

model LeadHistory {
  id           String   @id @default(uuid())
  leadId       String   @map("lead_id")
  previousData Json     @map("previous_data")
  newData      Json     @map("new_data")
  actionBy     String?  @map("action_by") 
  createdAt    DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_histories")
}

enum LeadStatus {
  NOVO
  AGUARDANDO_CONEXAO
  AGUARDANDO_RETORNO
  CONTATADO
  EM_NEGOCIACAO
  CONVERTIDO
  PERDIDO
  PAUSADO
}

enum LeadSource {
  MANUAL
  IMPORTACAO_CSV
  IMPORTACAO_XLSX
}

enum TemplateChannel {
  EMAIL
  LINKEDIN
  WHATSAPP
}

enum CadenceStatus {
  ACTIVE
  PAUSED
  FINISHED
  CANCELED
  REPLIED
}

model Operator {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  leads     Lead[]
  leadNotes LeadNote[]

  @@index([profileId])
  @@map("operators")
}

model LeadNote {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  operatorId String?  @map("operator_id") 
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  operator Operator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([operatorId])
  @@map("lead_notes")
}

model Notification {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  leadId      String?  @map("lead_id")
  title       String
  message     String
  isRead      Boolean  @default(false) @map("is_read")
  type        String   @default("CADENCE_OVERDUE")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([isRead])
  @@map("notifications")
}

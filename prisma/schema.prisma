generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// PERFIL DO USUÁRIO (estende auth.users do Supabase)
// ─────────────────────────────────────────────
model Profile {
  id        String   @id @default(uuid())
  authUid   String   @unique @map("auth_uid")
  name      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leads     Lead[]
  templates Template[]

  @@map("profiles")
}

// ─────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────
model Lead {
  id            String     @id @default(uuid())
  profileId     String     @map("profile_id")
  code          String     @unique @default(cuid())
  fullName      String     @map("full_name")
  company       String?
  jobTitle      String?    @map("job_title")
  email         String?
  phone         String?
  linkedinUrl   String?    @map("linkedin_url")
  whatsappUrl   String?    @map("whatsapp_url")
  status        LeadStatus @default(NOVO)
  source        LeadSource @default(MANUAL)
  notes         String?
  importBatchId String?    @map("import_batch_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  histories LeadHistory[]

  @@index([profileId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

// ─────────────────────────────────────────────
// TEMPLATES DE MENSAGEM
// ─────────────────────────────────────────────
model Template {
  id        String          @id @default(uuid())
  profileId String          @map("profile_id")
  name      String
  channel   TemplateChannel
  subject   String?
  body      String
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([channel])
  @@map("templates")
}

// ─────────────────────────────────────────────
// HISTÓRICO DO LEAD (Para rastrear Upserts e Merge de Importação)
// ─────────────────────────────────────────────
model LeadHistory {
  id           String   @id @default(uuid())
  leadId       String   @map("lead_id")
  previousData Json     @map("previous_data")
  newData      Json     @map("new_data")
  actionBy     String?  @map("action_by") // 'IMPORTACAO', 'MANUAL', 'SISTEMA'
  createdAt    DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_histories")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum LeadStatus {
  NOVO
  AGUARDANDO_CONEXAO
  AGUARDANDO_RETORNO
  CONTATADO
  EM_NEGOCIACAO
  CONVERTIDO
  PERDIDO
}

enum LeadSource {
  MANUAL
  IMPORTACAO_CSV
  IMPORTACAO_XLSX
}

enum TemplateChannel {
  EMAIL
  LINKEDIN
  WHATSAPP
}
